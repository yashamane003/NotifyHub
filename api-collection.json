{
  "info": {
    "name": "NotifyHub – Email Automation Platform API",
    "description": "API collection for auditing, templating, sending, and scheduling emails on NotifyHub.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register Operator/Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Yash Operator\",\n  \"email\": \"operator@notifyhub.com\",\n  \"password\": \"password123\",\n  \"role\": \"OPERATOR\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"operator@notifyhub.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Templates Module",
      "item": [
        {
          "name": "Get All Templates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/templates",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "templates"
              ]
            }
          }
        },
        {
          "name": "Create Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Welcome Onboarding\",\n  \"subject\": \"Welcome to NotifyHub, {{name}}!\",\n  \"body\": \"Hello {{name}},\\n\\nWelcome to our platform!\\n\\nBest regards,\\nTeam\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/templates",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "templates"
              ]
            }
          }
        },
        {
          "name": "Update Template",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Onboarding\",\n  \"subject\": \"Hey {{name}}, Welcome!\",\n  \"body\": \"Hello {{name}},\\n\\nGlad to have you aboard.\\n\\nCheers!\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/templates/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "templates",
                "1"
              ]
            }
          }
        },
        {
          "name": "Delete Template",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/templates/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "templates",
                "1"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Email Sending & Scheduling",
      "item": [
        {
          "name": "Send Email Immediately",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"templateId\": 1,\n  \"recipient\": \"test@example.com\",\n  \"variables\": {\n    \"name\": \"Yash\",\n    \"invoiceId\": \"INV-9023\",\n    \"amount\": \"450.00\"\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:8080/emails/send",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "emails",
                "send"
              ]
            }
          }
        },
